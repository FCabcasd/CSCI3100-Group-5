<div class="dashboard-page">
  <nav class="dashboard-nav">
    <a href="/menu" class="brand" style="text-decoration:none;color:#fff">
      <i class="bi bi-building"></i> <span data-i18n="brand">CUHK Venue Booking</span>
    </a>
    <div class="user-info">
      <span id="user-greeting"></span>
      <button class="btn-logout" onclick="toggleLang()" style="font-weight:600;">EN</button>
      <a href="/menu" class="btn-logout"><i class="bi bi-grid"></i> <span data-i18n="menu">Menu</span></a>
      <button class="btn-logout" id="logout-btn"><i class="bi bi-box-arrow-right"></i> <span data-i18n="logout">Logout</span></button>
    </div>
  </nav>

  <div class="page-container">
    <div class="page-header" style="display:flex;justify-content:space-between;align-items:center;">
      <div>
        <h1><i class="bi bi-bar-chart-line"></i> <span data-i18n="analytics_title">Analytics Dashboard</span></h1>
        <p data-i18n="analytics_sub">Usage overview for bookings, venues, and peak periods</p>
      </div>
      <button class="btn-apply-filter" onclick="refreshAnalytics()"><i class="bi bi-arrow-repeat"></i> <span data-i18n="refresh">Refresh</span></button>
    </div>

    <div class="analytics-stats-row">
      <div class="stat-card">
        <div class="stat-icon" style="background:#f0e6ff;color:#7b2d8e;"><i class="bi bi-calendar-check-fill"></i></div>
        <div>
          <div class="stat-number" id="stat-total">--</div>
          <div class="stat-label" data-i18n="total_bookings">Total Bookings</div>
        </div>
      </div>
      <div class="stat-card">
        <div class="stat-icon" style="background:#fff3e0;color:#e67e22;"><i class="bi bi-hourglass-split"></i></div>
        <div>
          <div class="stat-number" id="stat-pending">--</div>
          <div class="stat-label" data-i18n="pending_bookings">Pending</div>
        </div>
      </div>
      <div class="stat-card">
        <div class="stat-icon" style="background:#e6f7ee;color:#198754;"><i class="bi bi-check-circle-fill"></i></div>
        <div>
          <div class="stat-number" id="stat-confirmed">--</div>
          <div class="stat-label" data-i18n="confirmed_bookings">Confirmed</div>
        </div>
      </div>
      <div class="stat-card">
        <div class="stat-icon" style="background:#fee2e2;color:#dc2626;"><i class="bi bi-x-circle-fill"></i></div>
        <div>
          <div class="stat-number" id="stat-cancelled">--</div>
          <div class="stat-label" data-i18n="cancelled_bookings">Cancelled</div>
        </div>
      </div>
      <div class="stat-card">
        <div class="stat-icon" style="background:#f3e8ff;color:#6f42c1;"><i class="bi bi-slash-circle-fill"></i></div>
        <div>
          <div class="stat-number" id="stat-rejected">--</div>
          <div class="stat-label" data-i18n="rejected_bookings">Rejected</div>
        </div>
      </div>
    </div>

    <div class="analytics-grid">
      <div class="analytics-card">
        <h3><i class="bi bi-building me-2" style="color:#7b2d8e;"></i><span data-i18n="venue_usage">Venue Usage</span></h3>
        <div id="venues-list" class="analytics-card-content"><span class="text-muted" data-i18n="loading">Loading...</span></div>
      </div>
      <div class="analytics-card">
        <h3><i class="bi bi-clock-history me-2" style="color:#e67e22;"></i><span data-i18n="peak_times">Peak Times</span></h3>
        <div id="peak-times" class="analytics-card-content"><span class="text-muted" data-i18n="loading">Loading...</span></div>
      </div>
    </div>
  </div>
</div>

<script>
document.addEventListener("turbo:load", () => {
  if (!document.getElementById("stat-total")) return;
  const token = localStorage.getItem("access_token");

  if (token) {
    fetch("/api/auth/me", { headers: { Authorization: "Bearer " + token } })
      .then(r => { if (!r.ok) throw 0; return r.json(); })
      .then(u => { document.getElementById("user-greeting").textContent = t('hi') + (u.full_name || u.username); })
      .catch(() => {});
  }
  document.getElementById("logout-btn").onclick = () => {
    localStorage.removeItem("access_token"); localStorage.removeItem("refresh_token");
    window.location.href = "/";
  };

  window.refreshAnalytics = function() { loadStats(); loadVenueUsage(); loadPeakTimes(); };

  async function loadStats() {
    try {
      const r = await fetch("/api/analytics/bookings/stats");
      const d = await r.json();
      document.getElementById("stat-total").textContent = d.total_bookings ?? '--';
      document.getElementById("stat-pending").textContent = d.pending_bookings ?? '--';
      document.getElementById("stat-confirmed").textContent = d.confirmed_bookings ?? '--';
      document.getElementById("stat-cancelled").textContent = d.cancelled_bookings ?? '--';
      document.getElementById("stat-rejected").textContent = d.rejected_bookings ?? '--';
    } catch(e) { console.error(e); }
  }

  async function loadVenueUsage() {
    const el = document.getElementById("venues-list");
    try {
      const r = await fetch("/api/analytics/venues/usage");
      const data = await r.json();
      if (!data || !data.length) { el.innerHTML = '<span class="text-muted">' + t('no_data') + '</span>'; return; }
      el.innerHTML = data.map(v => `
        <div class="analytics-row">
          <div class="analytics-row-label">
            <i class="bi bi-geo-alt" style="color:#7b2d8e;margin-right:6px;"></i>${esc(v.venue_name)}
          </div>
          <div class="analytics-row-bar">
            <div class="bar-fill" style="width:${Math.min(100, (v.booking_count / Math.max(...data.map(x=>x.booking_count))) * 100)}%;"></div>
          </div>
          <div class="analytics-row-value">${v.booking_count} <span class="text-muted small">(${v.total_hours_booked}h)</span></div>
        </div>
      `).join("");
    } catch(e) { el.innerHTML = '<span class="text-danger">' + t('load_fail') + '</span>'; }
  }

  async function loadPeakTimes() {
    const el = document.getElementById("peak-times");
    try {
      const r = await fetch("/api/analytics/peak-times");
      const data = await r.json();
      const hourly = data.hourly_peak_times || [];
      const weekday = data.weekday_peak_times || [];
      const maxH = Math.max(...hourly.map(x=>x.booking_count), 1);
      const maxW = Math.max(...weekday.map(x=>x.booking_count), 1);
      el.innerHTML = `
        <div style="margin-bottom:1rem;">
          <div class="analytics-sub-title"><i class="bi bi-sunrise me-1"></i> ${t('by_hour') || 'By Hour'}</div>
          ${hourly.length ? hourly.map(h => `
            <div class="analytics-row">
              <div class="analytics-row-label" style="min-width:55px;">${h.hour}:00</div>
              <div class="analytics-row-bar"><div class="bar-fill bar-gold" style="width:${(h.booking_count/maxH)*100}%;"></div></div>
              <div class="analytics-row-value">${h.booking_count}</div>
            </div>
          `).join("") : '<span class="text-muted">' + t('no_data') + '</span>'}
        </div>
        <div>
          <div class="analytics-sub-title"><i class="bi bi-calendar-week me-1"></i> ${t('by_weekday') || 'By Weekday'}</div>
          ${weekday.length ? weekday.map(w => `
            <div class="analytics-row">
              <div class="analytics-row-label" style="min-width:55px;">${w.day}</div>
              <div class="analytics-row-bar"><div class="bar-fill" style="width:${(w.booking_count/maxW)*100}%;"></div></div>
              <div class="analytics-row-value">${w.booking_count}</div>
            </div>
          `).join("") : '<span class="text-muted">' + t('no_data') + '</span>'}
        </div>
      `;
    } catch(e) { el.innerHTML = '<span class="text-danger">' + t('load_fail') + '</span>'; }
  }

  function esc(s) { return String(s||"").replace(/[&<>"']/g,c=>({'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;','\'':'&#39;'}[c])); }
  refreshAnalytics();
});
</script>
