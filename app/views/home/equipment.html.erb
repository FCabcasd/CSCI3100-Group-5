<div class="dashboard-page">
  <nav class="dashboard-nav">
    <a href="/menu" class="brand" style="text-decoration:none;color:#fff">
      <i class="bi bi-building"></i> <span data-i18n="brand">CUHK Venue Booking</span>
    </a>
    <div class="user-info">
      <span id="user-greeting"></span>
      <button class="btn-logout" id="lang-toggle-btn" onclick="toggleLang()" style="font-weight:600;">EN</button>
      <a href="/menu" class="btn-logout"><i class="bi bi-grid"></i> <span data-i18n="menu">Menu</span></a>
      <button class="btn-logout" id="logout-btn"><i class="bi bi-box-arrow-right"></i> <span data-i18n="logout">Logout</span></button>
    </div>
  </nav>

  <div class="page-container">
    <div class="page-header">
      <h1><i class="bi bi-box-seam"></i> <span data-i18n="browse_equip">Browse Equipment</span></h1>
      <p data-i18n="browse_equip_sub">Search and explore available equipment across all departments</p>
    </div>

    <div class="search-bar">
      <div class="search-input-wrap">
        <i class="bi bi-search"></i>
        <input type="text" id="equip-search" data-i18n-placeholder="ph_search_equip" placeholder="Type to search equipment..." autocomplete="off">
        <button class="btn-clear" id="clear-search" style="display:none"><i class="bi bi-x-lg"></i></button>
        <div id="search-dropdown" class="search-dropdown"></div>
      </div>
      <div class="filter-row">
        <select id="filter-type" class="filter-select"><option value="" data-i18n="any_type">Any Type</option></select>
        <select id="filter-status" class="filter-select">
          <option value="" data-i18n="any_status">Any Status</option>
          <option value="available" data-i18n="available">Available</option>
          <option value="in_use" data-i18n="in_use">In Use</option>
          <option value="maintenance" data-i18n="maintenance">Maintenance</option>
        </select>
        <button class="btn-apply-filter" id="apply-filter-btn"><i class="bi bi-funnel"></i> <span data-i18n="apply_filters">Apply Filters</span></button>
        <span id="result-count" class="result-count"></span>
      </div>
    </div>

    <div id="equip-grid" class="venues-grid">
      <div class="loading-spinner"><span class="spinner-border text-secondary"></span> <span data-i18n="loading_equip">Loading equipment...</span></div>
    </div>
    <div id="load-more-wrap" class="text-center mt-3 mb-4" style="display:none">
      <button id="load-more-btn" class="btn-load-more" data-i18n="load_more">Load More</button>
    </div>

    <!-- Inline Booking Form -->
    <div id="equip-book-section" style="display:none;margin-top:2rem;">
      <div style="background:#fff;border-radius:16px;box-shadow:0 4px 20px rgba(13,110,253,0.10);overflow:hidden;">
        <div style="background:linear-gradient(135deg,#0d6efd,#7b2d8e);padding:18px 24px;display:flex;align-items:center;justify-content:space-between;">
          <h3 style="margin:0;color:#fff;font-size:1.15rem;font-weight:700;"><i class="bi bi-calendar-plus me-2"></i><span data-i18n="book_equip_title">Book Equipment</span></h3>
          <button onclick="deselectEquip()" style="background:rgba(255,255,255,0.2);border:none;color:#fff;border-radius:8px;padding:6px 14px;cursor:pointer;font-size:.85rem;"><i class="bi bi-x-lg me-1"></i><span data-i18n="btn_deselect">Deselect</span></button>
        </div>
        <div style="padding:20px 24px;">
          <div id="selected-equip-info" style="display:flex;align-items:center;gap:12px;padding:14px 18px;border-radius:12px;background:linear-gradient(135deg,#e8f4fd,#f0e6ff);margin-bottom:1.2rem;">
            <div style="width:48px;height:48px;border-radius:12px;background:#0d6efd;color:#fff;display:flex;align-items:center;justify-content:center;font-size:1.3rem;flex-shrink:0;">
              <i class="bi bi-box-seam-fill"></i>
            </div>
            <div>
              <div id="book-equip-name" style="font-weight:700;font-size:1.05rem;color:#1a1a2e;"></div>
              <div id="book-equip-type" style="font-size:.85rem;color:#666;"></div>
            </div>
            <div style="margin-left:auto;">
              <i class="bi bi-check-circle-fill" style="color:#198754;font-size:1.5rem;"></i>
            </div>
          </div>
          <form id="equip-book-form">
            <div style="margin-bottom:1rem;">
              <label style="font-weight:600;font-size:.9rem;margin-bottom:6px;display:block;">
                <i class="bi bi-pencil-square" style="color:#7b2d8e;margin-right:4px;"></i><span data-i18n="lbl_book_title">Booking Title</span>
              </label>
              <input type="text" class="form-control form-control-lg" id="ebook-title"
                     data-i18n-placeholder="ph_book_equip" placeholder="e.g. Lab equipment, Event devices" required maxlength="40"
                     style="border-radius:10px;border:2px solid #e0e0e0;padding:10px 14px;font-size:.95rem;">
            </div>
            <div style="display:grid;grid-template-columns:1fr 1fr;gap:12px;margin-bottom:1rem;">
              <div>
                <label style="font-weight:600;font-size:.9rem;margin-bottom:6px;display:block;">
                  <i class="bi bi-clock" style="color:#0d6efd;margin-right:4px;"></i><span data-i18n="lbl_start_time">Start Time</span>
                </label>
                <input type="text" class="form-control" id="ebook-start" required readonly
                       placeholder="yyyy-mm-dd HH:MM"
                       style="border-radius:10px;border:2px solid #e0e0e0;padding:8px 12px;background:#fff;">
              </div>
              <div>
                <label style="font-weight:600;font-size:.9rem;margin-bottom:6px;display:block;">
                  <i class="bi bi-clock-history" style="color:#e67e22;margin-right:4px;"></i><span data-i18n="lbl_end_time">End Time</span>
                </label>
                <input type="text" class="form-control" id="ebook-end" required readonly
                       placeholder="yyyy-mm-dd HH:MM"
                       style="border-radius:10px;border:2px solid #e0e0e0;padding:8px 12px;background:#fff;">
              </div>
            </div>
            <div style="margin-bottom:1rem;">
              <label style="font-weight:600;font-size:.9rem;margin-bottom:6px;display:block;">
                <i class="bi bi-chat-left-text" style="color:#198754;margin-right:4px;"></i><span data-i18n="lbl_remarks">Remarks (optional)</span>
              </label>
              <textarea class="form-control" id="ebook-remarks" rows="2" maxlength="200"
                        data-i18n-placeholder="ph_remarks" placeholder="Additional notes..."
                        style="border-radius:10px;border:2px solid #e0e0e0;padding:10px 14px;resize:vertical;"></textarea>
            </div>
            <div id="ebook-error" style="display:none;background:#fee;border:1px solid #fcc;color:#c00;padding:8px 14px;border-radius:10px;font-size:.85rem;margin-bottom:1rem;"></div>
            <button type="submit" style="width:100%;padding:12px;border:none;border-radius:12px;background:linear-gradient(135deg,#0d6efd,#7b2d8e);color:#fff;font-size:1rem;font-weight:700;cursor:pointer;transition:transform .15s,box-shadow .15s;">
              <i class="bi bi-check-circle me-2"></i><span data-i18n="btn_submit_booking">Confirm Booking</span>
            </button>
          </form>
        </div>
      </div>
    </div>
  </div>
</div>

<!-- Detail Overlay -->
<div id="equipOverlay" onclick="this.style.display='none'" style="display:none;position:fixed;top:0;left:0;width:100%;height:100%;z-index:9999;background:rgba(0,0,0,0.5);">
  <div onclick="event.stopPropagation()" style="position:absolute;top:50%;left:50%;transform:translate(-50%,-50%);width:92%;max-width:580px;max-height:85vh;background:#fff;border-radius:18px;box-shadow:0 12px 48px rgba(0,0,0,0.25);overflow-y:auto;">
    <div style="position:sticky;top:0;background:#fff;z-index:10;display:flex;align-items:center;justify-content:space-between;padding:18px 24px 14px;border-bottom:1px solid #eee;">
      <h4 id="modal-equip-name" style="font-weight:700;margin:0;font-size:1.3rem;"></h4>
      <button onclick="document.getElementById('equipOverlay').style.display='none'" style="width:40px;height:40px;border-radius:50%;border:1px solid #d1d5db;background:#f3f4f6;color:#374151;font-size:1.4rem;cursor:pointer;display:flex;align-items:center;justify-content:center;flex-shrink:0;transition:all .2s;" onmouseover="this.style.background='#fee2e2';this.style.color='#dc2626';this.style.borderColor='#fca5a5'" onmouseout="this.style.background='#f3f4f6';this.style.color='#374151';this.style.borderColor='#d1d5db'"><i class="bi bi-x-lg"></i></button>
    </div>
    <div id="modal-equip-body" style="padding:20px 24px 24px;"></div>
    <div style="padding:0 24px 20px;">
      <button id="select-equip-btn" style="width:100%;padding:12px;border:none;border-radius:12px;background:linear-gradient(135deg,#0d6efd,#7b2d8e);color:#fff;font-size:1rem;font-weight:700;cursor:pointer;display:flex;align-items:center;justify-content:center;gap:8px;transition:transform .15s,box-shadow .15s;" onmouseover="this.style.transform='translateY(-1px)';this.style.boxShadow='0 6px 20px rgba(13,110,253,0.3)'" onmouseout="this.style.transform='';this.style.boxShadow=''">
        <i class="bi bi-check2-square" style="font-size:1.2rem;"></i> <span data-i18n="btn_select_equip">Select this equipment for booking</span>
      </button>
    </div>
  </div>
</div>

<script>
document.addEventListener("turbo:load", () => {
  if (!document.getElementById("equip-grid")) return;

  const token = localStorage.getItem("access_token");

  let allEquip = [];
  let displayedCount = 0;
  const PAGE_SIZE = 12;
  const grid = document.getElementById("equip-grid");
  const searchInput = document.getElementById("equip-search");
  const clearBtn = document.getElementById("clear-search");
  const dropdown = document.getElementById("search-dropdown");
  const filterType = document.getElementById("filter-type");
  const filterStatus = document.getElementById("filter-status");
  const resultCount = document.getElementById("result-count");
  const loadMoreWrap = document.getElementById("load-more-wrap");
  const loadMoreBtn = document.getElementById("load-more-btn");
  const applyBtn = document.getElementById("apply-filter-btn");
  const authHeaders = token ? { "Authorization": "Bearer " + token, "Accept": "application/json" } : { "Accept": "application/json" };

  // Initialize flatpickr date pickers
  const fpOpts = { enableTime: true, dateFormat: "Y-m-d H:i", time_24hr: true, locale: "en" };
  flatpickr("#ebook-start", fpOpts);
  flatpickr("#ebook-end", fpOpts);

  if (token) {
    fetch("<%= api_auth_me_path %>", { headers: authHeaders })
      .then(r => { if (!r.ok) throw new Error(); return r.json(); })
      .then(u => { if (u) document.getElementById("user-greeting").textContent = t('hi') + (u.full_name || u.username); })
      .catch(() => {});
  }
  document.getElementById("logout-btn").addEventListener("click", () => {
    localStorage.removeItem("access_token"); localStorage.removeItem("refresh_token");
    window.location.href = "/";
  });

  fetchEquipment();

  function fetchEquipment(query) {
    const url = query ? "/api/equipment/browse?limit=100&q=" + encodeURIComponent(query) : "/api/equipment/browse?limit=100";
    grid.innerHTML = '<div class="loading-spinner"><span class="spinner-border text-secondary"></span> ' + t('loading') + '</div>';
    fetch(url)
      .then(r => r.json())
      .then(data => { allEquip = data; populateTypeFilter(); applyClientFilters(); })
      .catch(() => { grid.innerHTML = '<p class="text-center text-muted">' + t('failed_load_equip') + '</p>'; });
  }

  function populateTypeFilter() {
    const current = filterType.value;
    filterType.innerHTML = '<option value="">' + t('any_type') + '</option>';
    const types = [...new Set(allEquip.map(e => e.equipment_type).filter(Boolean))].sort();
    types.forEach(tp => {
      const opt = document.createElement("option");
      opt.value = tp; opt.textContent = tp.replace(/_/g, ' ').replace(/\b\w/g, c => c.toUpperCase());
      if (tp === current) opt.selected = true;
      filterType.appendChild(opt);
    });
  }

  let debounceTimer;
  searchInput.addEventListener("input", () => {
    const q = searchInput.value.trim();
    clearBtn.style.display = q ? "block" : "none";
    clearTimeout(debounceTimer);
    if (!q) { dropdown.classList.remove("show"); fetchEquipment(); return; }
    debounceTimer = setTimeout(() => liveSearch(q), 250);
  });

  function liveSearch(q) {
    fetch("/api/equipment/browse?limit=8&q=" + encodeURIComponent(q))
      .then(r => r.json())
      .then(results => {
        if (!results.length) {
          dropdown.innerHTML = '<div class="dropdown-empty">' + t('no_equip_found') + '</div>';
        } else {
          dropdown.innerHTML = results.map(e =>
            '<div class="dropdown-item" data-id="' + e.id + '">' +
              '<strong>' + highlightMatch(escHtml(e.name), q) + '</strong>' +
              '<small>' + escHtml(e.equipment_type || "") + ' &middot; Avail: ' + e.available_quantity + '/' + e.quantity + ' &middot; ' + statusLabel(e.status) + '</small>' +
            '</div>'
          ).join("");
        }
        dropdown.classList.add("show");
      });
  }

  function highlightMatch(text, query) {
    const re = new RegExp("(" + query.replace(/[.*+?^${}()|[\]\\]/g, '\\$&') + ")", "gi");
    return text.replace(re, '<mark>$1</mark>');
  }
  function statusLabel(s) { return (s || 'unknown').replace(/_/g, ' ').replace(/\b\w/g, c => c.toUpperCase()); }

  dropdown.addEventListener("click", (e) => {
    const item = e.target.closest(".dropdown-item");
    if (!item) return;
    dropdown.classList.remove("show");
    searchInput.value = ""; clearBtn.style.display = "none";
    fetchEquipment();
    setTimeout(() => showEquipDetail(parseInt(item.dataset.id)), 400);
  });
  document.addEventListener("click", (e) => {
    if (!e.target.closest(".search-input-wrap")) dropdown.classList.remove("show");
  });
  searchInput.addEventListener("keydown", (e) => {
    if (e.key === "Enter") { e.preventDefault(); dropdown.classList.remove("show"); fetchEquipment(searchInput.value.trim()); }
  });
  clearBtn.addEventListener("click", () => {
    searchInput.value = ""; clearBtn.style.display = "none";
    dropdown.classList.remove("show"); fetchEquipment();
  });

  applyBtn.addEventListener("click", applyClientFilters);
  filterType.addEventListener("change", applyClientFilters);
  filterStatus.addEventListener("change", applyClientFilters);

  function applyClientFilters() {
    displayedCount = 0;
    const type = filterType.value, status = filterStatus.value;
    const filtered = allEquip.filter(e => {
      if (type && e.equipment_type !== type) return false;
      if (status && e.status !== status) return false;
      return true;
    });
    resultCount.textContent = filtered.length + t('items_found');
    grid.innerHTML = "";
    if (!filtered.length) {
      grid.innerHTML = '<p class="text-center text-muted py-4">' + t('no_equip_match') + '</p>';
      loadMoreWrap.style.display = "none"; return;
    }
    showMore(filtered);
  }

  function showMore(filtered) {
    const slice = filtered.slice(displayedCount, displayedCount + PAGE_SIZE);
    slice.forEach(e => grid.insertAdjacentHTML("beforeend", equipCard(e)));
    displayedCount += slice.length;
    loadMoreWrap.style.display = displayedCount < filtered.length ? "block" : "none";
  }
  loadMoreBtn.addEventListener("click", () => {
    const type = filterType.value, status = filterStatus.value;
    const filtered = allEquip.filter(e => {
      if (type && e.equipment_type !== type) return false;
      if (status && e.status !== status) return false;
      return true;
    });
    showMore(filtered);
  });

  function statusBadge(s) {
    const map = { available:'bg-success', in_use:'bg-warning text-dark', maintenance:'bg-danger', unavailable:'bg-secondary' };
    return '<span class="badge ' + (map[s] || 'bg-secondary') + '">' + statusLabel(s) + '</span>';
  }
  function typeIcon(tp) {
    const icons = { av_equipment:'bi-camera-video', presentation:'bi-projector', computing:'bi-pc-display',
      furniture:'bi-lamp', lab_equipment:'bi-moisture', sports:'bi-dribbble', audio:'bi-speaker',
      outdoor:'bi-tree', event:'bi-calendar-event', study:'bi-book', medical:'bi-heart-pulse' };
    return '<i class="bi ' + (icons[tp] || 'bi-box-seam') + '"></i>';
  }
  function equipCard(e) {
    const typeLabel = (e.equipment_type || "Other").replace(/_/g, ' ').replace(/\b\w/g, c => c.toUpperCase());
    return '<div class="venue-card equip-card" onclick="showEquipDetail(' + e.id + ')">' +
      '<div class="venue-card-header"><h3>' + typeIcon(e.equipment_type) + ' ' + escHtml(e.name) + '</h3>' + statusBadge(e.status) + '</div>' +
      '<p class="venue-desc">' + escHtml(e.description || "") + '</p>' +
      '<div class="equip-meta"><span class="venue-feat">' + typeIcon(e.equipment_type) + ' ' + typeLabel + '</span>' +
        '<span class="venue-feat"><i class="bi bi-stack"></i> Avail: ' + e.available_quantity + '/' + e.quantity + '</span></div></div>';
  }
  function escHtml(s) { const d = document.createElement("div"); d.textContent = s; return d.innerHTML; }

  let currentEquipId = null;
  window.showEquipDetail = function(id) {
    const e = allEquip.find(x => x.id === id);
    if (!e) return;
    currentEquipId = e.id;
    document.getElementById("modal-equip-name").textContent = e.name;
    const typeLabel = (e.equipment_type || "Other").replace(/_/g, ' ').replace(/\b\w/g, c => c.toUpperCase());
    document.getElementById("modal-equip-body").innerHTML =
      '<div class="detail-grid">' +
        '<div class="detail-item"><div class="detail-icon" style="background:#f0e6ff;color:#7b2d8e">' + typeIcon(e.equipment_type) + '</div>' +
          '<div><div class="detail-label">' + t('lbl_type') + '</div><div class="detail-value">' + typeLabel + '</div></div></div>' +
        '<div class="detail-item"><div class="detail-icon" style="background:#e6f7ee;color:#198754"><i class="bi bi-stack"></i></div>' +
          '<div><div class="detail-label">' + t('lbl_quantity') + '</div><div class="detail-value">' + e.available_quantity + ' / ' + e.quantity + '</div></div></div>' +
        '<div class="detail-item"><div class="detail-icon" style="background:#fff3e0;color:#e67e22"><i class="bi bi-reception-4"></i></div>' +
          '<div><div class="detail-label">' + t('lbl_status') + '</div><div class="detail-value">' + statusBadge(e.status) + '</div></div></div>' +
        '<div class="detail-item detail-item-wide"><div class="detail-icon" style="background:#e8f4fd;color:#0d6efd"><i class="bi bi-info-circle-fill"></i></div>' +
          '<div><div class="detail-label">' + t('lbl_description') + '</div><div class="detail-value">' + escHtml(e.description || t('lbl_no_desc')) + '</div></div></div>' +
      '</div>';
    document.getElementById("equipOverlay").style.display = "block";
  };

  // Select equipment for booking
  document.getElementById("select-equip-btn").onclick = function() {
    if (!currentEquipId) return;
    const e = allEquip.find(x => x.id === currentEquipId);
    if (!e) return;
    const typeLabel = (e.equipment_type || "Other").replace(/_/g, ' ').replace(/\b\w/g, c => c.toUpperCase());
    document.getElementById("book-equip-name").textContent = e.name;
    document.getElementById("book-equip-type").textContent = typeLabel;
    document.getElementById("equip-book-section").style.display = "block";
    document.getElementById("equipOverlay").style.display = "none";
    setTimeout(() => {
      document.getElementById("equip-book-section").scrollIntoView({ behavior: 'smooth', block: 'center' });
    }, 100);
  };

  window.deselectEquip = function() {
    currentEquipId = null;
    document.getElementById("equip-book-section").style.display = "none";
  };

  document.getElementById("equip-book-form").onsubmit = function(ev) {
    ev.preventDefault();
    if (!currentEquipId) return;
    const title = document.getElementById("ebook-title").value.trim();
    const start = document.getElementById("ebook-start").value;
    const end = document.getElementById("ebook-end").value;
    const remarks = document.getElementById("ebook-remarks").value.trim();
    const errorBox = document.getElementById("ebook-error");
    errorBox.style.display = "none";
    if (!title || !start || !end) { errorBox.textContent = t('err_fill_all'); errorBox.style.display = "block"; return; }
    if (new Date(start) >= new Date(end)) { errorBox.textContent = t('err_end_before_start'); errorBox.style.display = "block"; return; }
    const submitBtn = ev.target.querySelector('button[type="submit"]');
    submitBtn.disabled = true;
    submitBtn.innerHTML = '<span class="spinner-border spinner-border-sm me-2"></span>' + t('btn_submitting');
    fetch("/api/bookings", {
      method: "POST",
      headers: { "Content-Type": "application/json", "Authorization": "Bearer " + token },
      body: JSON.stringify({ equipment_ids: [currentEquipId], title, start_time: start, end_time: end, remarks })
    })
      .then(r => r.json())
      .then(data => {
        submitBtn.disabled = false;
        submitBtn.innerHTML = '<i class="bi bi-check-circle me-2"></i>' + t('btn_submit_booking');
        if (data.error || data.errors) { errorBox.textContent = data.error || data.errors; errorBox.style.display = "block"; }
        else {
          alert(t('book_equip_success'));
          deselectEquip();
          document.getElementById("ebook-title").value = '';
          document.getElementById("ebook-start").value = '';
          document.getElementById("ebook-end").value = '';
          document.getElementById("ebook-remarks").value = '';
        }
      })
      .catch(() => {
        submitBtn.disabled = false;
        submitBtn.innerHTML = '<i class="bi bi-check-circle me-2"></i>' + t('btn_submit_booking');
        errorBox.textContent = t('book_fail'); errorBox.style.display = "block";
      });
  };

  document.addEventListener("langchange", () => {
    if (allEquip.length) applyClientFilters();
  });
});
</script>
