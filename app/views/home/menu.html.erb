<div class="dashboard-page">
  <nav class="dashboard-nav">
    <span class="brand"><i class="bi bi-building"></i> <span data-i18n="brand">CUHK Venue Booking</span></span>
    <div class="user-info">
      <span id="user-greeting"></span>
      <span class="badge bg-light text-dark" id="user-points"></span>
      <button class="btn-logout" id="lang-toggle-btn" onclick="toggleLang()" style="font-weight:600;">EN</button>
      <button class="btn-logout" id="logout-btn"><i class="bi bi-box-arrow-right"></i> <span data-i18n="logout">Logout</span></button>
    </div>
  </nav>

  <div class="dashboard-grid" id="dashboard-grid">
    <a href="/catalog" class="dash-card">
      <div class="card-icon" style="background:linear-gradient(135deg,#7b2d8e,#9b4dca)">
        <i class="bi bi-geo-alt"></i>
      </div>
      <div>
        <h3 data-i18n="card_venues">Browse Venues</h3>
        <p data-i18n="card_venues_desc">Search and explore available venues</p>
      </div>
    </a>

    <a href="/equipment" class="dash-card">
      <div class="card-icon" style="background:linear-gradient(135deg,#2d6a8e,#4d9eca)">
        <i class="bi bi-tools"></i>
      </div>
      <div>
        <h3 data-i18n="card_equip">Equipment</h3>
        <p data-i18n="card_equip_desc">View and book equipment</p>
      </div>
    </a>

    <a href="/user_bookings" class="dash-card">
      <div class="card-icon" style="background:linear-gradient(135deg,#8e6a2d,#caa04d)">
        <i class="bi bi-calendar-check"></i>
      </div>
      <div>
        <h3 data-i18n="card_bookings">My Bookings</h3>
        <p data-i18n="card_bookings_desc">View, manage and check in</p>
      </div>
    </a>

    <a href="/venue_bookings" class="dash-card">
      <div class="card-icon" style="background:linear-gradient(135deg,#2d8e6a,#4dcaa0)">
        <i class="bi bi-calendar3"></i>
      </div>
      <div>
        <h3 data-i18n="card_calendar">Venue Calendar</h3>
        <p data-i18n="card_calendar_desc">See venue availability</p>
      </div>
    </a>

    <a href="/ai_assistant" class="dash-card">
      <div class="card-icon" style="background:linear-gradient(135deg,#f59e42,#f7c873)">
        <i class="bi bi-robot"></i>
      </div>
      <div>
        <h3 data-i18n="card_ai">AI Consultant</h3>
        <p data-i18n="card_ai_desc">Smart Q&A and recommendations</p>
      </div>
    </a>

    <!-- Admin-only cards (hidden by default) -->
    <a href="/admin_panel" class="dash-card admin-card" style="display:none">
      <div class="card-icon" style="background:linear-gradient(135deg,#8e2d2d,#ca4d4d)">
        <i class="bi bi-shield-lock"></i>
      </div>
      <div>
        <h3 data-i18n="card_profile">My Profile</h3>
        <p data-i18n="card_profile_desc">View your account details and points</p>
      </div>
    </a>

    <a href="/analytics" class="dash-card admin-card" style="display:none">
      <div class="card-icon" style="background:linear-gradient(135deg,#4a2d8e,#7a4dca)">
        <i class="bi bi-bar-chart-line"></i>
      </div>
      <div>
        <h3 data-i18n="card_analytics">Analytics</h3>
        <p data-i18n="card_analytics_desc">Usage stats and reports</p>
      </div>
    </a>

    <a href="/admin_users" class="dash-card admin-card" style="display:none">
      <div class="card-icon" style="background:linear-gradient(135deg,#8e2d2d,#ca4d4d)">
        <i class="bi bi-shield-lock"></i>
      </div>
      <div>
        <h3 data-i18n="card_admin">Admin Panel</h3>
        <p data-i18n="card_admin_desc">Manage users and bookings</p>
      </div>
    </a>
  </div>
</div>

<script>
document.addEventListener("turbo:load", () => {
  if (!document.getElementById("dashboard-grid")) return;
  const token = localStorage.getItem("access_token");
  if (!token) {
    window.location.href = "/";
    return;
  }

  fetch("<%= api_auth_me_path %>", {
    headers: {
      "Authorization": "Bearer " + token,
      "Accept": "application/json"
    }
  })
    .then(res => {
      if (res.status === 401) {
        localStorage.removeItem("access_token");
        localStorage.removeItem("refresh_token");
        window.location.href = "/";
        return null;
      }
      if (!res.ok) return null;
      return res.json();
    })
    .then(user => {
      if (!user) return;

      document.getElementById("user-greeting").textContent =
        t('hi') + (user.full_name || user.username);
      document.getElementById("user-points").innerHTML =
        '<i class="bi bi-coin"></i> ' + user.points + " " + t('pts');

      if (user.role === "admin" || user.role === "tenant_admin") {
        document.querySelectorAll(".admin-card").forEach(card => {
          card.style.display = "flex";
        });
      }
    })
    .catch((err) => {
      console.error("Auth check failed:", err);
      // Don't redirect on network errors - just show default state
      document.getElementById("user-greeting").textContent = t('hi') + "User";
    });

  document.getElementById("logout-btn").addEventListener("click", () => {
    localStorage.removeItem("access_token");
    localStorage.removeItem("refresh_token");
    window.location.href = "/";
  });
});
</script>
