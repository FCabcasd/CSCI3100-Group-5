<div class="dashboard-page">
  <nav class="dashboard-nav">
    <a href="/menu" class="brand" style="text-decoration:none;color:#fff">
      <i class="bi bi-building"></i> <span data-i18n="brand">CUHK Venue Booking</span>
    </a>
    <div class="user-info">
      <span id="user-greeting"></span>
      <button class="btn-logout" onclick="toggleLang()" style="font-weight:600;">EN</button>
      <a href="/menu" class="btn-logout"><i class="bi bi-grid"></i> <span data-i18n="menu">Menu</span></a>
      <button class="btn-logout" id="logout-btn"><i class="bi bi-box-arrow-right"></i> <span data-i18n="logout">Logout</span></button>
    </div>
  </nav>

  <div class="page-container" style="max-width:680px;">
    <div class="page-header">
      <h1><i class="bi bi-person-circle"></i> <span data-i18n="my_profile">My Profile</span></h1>
      <p data-i18n="profile_sub">View your account information and current status</p>
    </div>

    <div class="profile-card-styled">
      <div class="profile-avatar-row" id="profile-avatar-row">
        <div class="profile-avatar"><i class="bi bi-person-fill"></i></div>
        <div>
          <div class="profile-name" id="profile-name">--</div>
          <div class="profile-role" id="profile-role">--</div>
        </div>
      </div>
      <div id="profile-details" class="profile-details">
        <span class="text-muted" data-i18n="loading">Loading...</span>
      </div>
    </div>
  </div>
</div>

<script>
document.addEventListener("turbo:load", () => {
  if (!document.getElementById("profile-details")) return;
  const token = localStorage.getItem("access_token");

  document.getElementById("logout-btn").onclick = () => {
    localStorage.removeItem("access_token"); localStorage.removeItem("refresh_token");
    window.location.href = "/";
  };

  async function loadProfile() {
    if (!token) {
      document.getElementById("profile-details").innerHTML = '<span class="text-muted">' + t('no_token') + '</span>';
      return;
    }
    try {
      const r = await fetch("/api/auth/me", { headers: { Authorization: "Bearer " + token } });
      const data = await r.json();
      if (!r.ok) { document.getElementById("profile-details").innerHTML = '<span class="text-danger">' + (data.error || t('profile_fail')) + '</span>'; return; }

      document.getElementById("user-greeting").textContent = t('hi') + (data.full_name || data.username);
      document.getElementById("profile-name").textContent = data.full_name || data.username;
      document.getElementById("profile-role").textContent = data.role;

      document.getElementById("profile-details").innerHTML = `
        <div class="profile-detail-row">
          <div class="profile-detail-icon" style="background:#f0e6ff;color:#7b2d8e;"><i class="bi bi-person-badge-fill"></i></div>
          <div>
            <div class="profile-detail-label">${t('lbl_username')}</div>
            <div class="profile-detail-value">${esc(data.username)}</div>
          </div>
        </div>
        <div class="profile-detail-row">
          <div class="profile-detail-icon" style="background:#e8f4fd;color:#0d6efd;"><i class="bi bi-envelope-fill"></i></div>
          <div>
            <div class="profile-detail-label">${t('lbl_email')}</div>
            <div class="profile-detail-value">${esc(data.email)}</div>
          </div>
        </div>
        <div class="profile-detail-row">
          <div class="profile-detail-icon" style="background:#e6f7ee;color:#198754;"><i class="bi bi-person-fill"></i></div>
          <div>
            <div class="profile-detail-label">${t('lbl_fullname')}</div>
            <div class="profile-detail-value">${esc(data.full_name || '-')}</div>
          </div>
        </div>
        <div class="profile-detail-row">
          <div class="profile-detail-icon" style="background:#fff3e0;color:#e67e22;"><i class="bi bi-building"></i></div>
          <div>
            <div class="profile-detail-label">${t('lbl_tenant')}</div>
            <div class="profile-detail-value">${data.tenant_id ?? t('na')}</div>
          </div>
        </div>
        <div class="profile-detail-row">
          <div class="profile-detail-icon" style="background:#f0e6ff;color:#7b2d8e;"><i class="bi bi-star-fill"></i></div>
          <div>
            <div class="profile-detail-label">${t('lbl_points')}</div>
            <div class="profile-detail-value" style="font-size:1.2rem;font-weight:700;color:#7b2d8e;">${data.points}</div>
          </div>
        </div>
      `;
    } catch(e) {
      document.getElementById("profile-details").innerHTML = '<span class="text-danger">' + t('profile_fail') + '</span>';
    }
  }

  function esc(s) { return String(s||"").replace(/[&<>"']/g,c=>({'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;','\'':'&#39;'}[c])); }
  document.addEventListener("langchange", () => { loadProfile(); });
  loadProfile();
});
</script>
